{
  "name": "soulforge",
  "private": true,
  "packageManager": "npm@11.9.0",
  "scripts": {
    "ui:workspace:install": "npm install --prefix ui-workspace",
    "ui:dev": "npm --prefix ui-workspace run dev",
    "ui:build": "npm --prefix ui-workspace run build",
    "ui:preview": "npm --prefix ui-workspace run preview --",
    "ui:validate": "npm --prefix ui-workspace run validate",
    "ui:lint:catalog": "UI_LINT_CANONICAL_ROOT=.. npm --prefix ui-workspace run lint:catalog",
    "ui:lint:ui-state": "UI_LINT_CANONICAL_ROOT=.. npm --prefix ui-workspace run lint:ui-state",
    "ui:lint:read-only": "UI_LINT_CANONICAL_ROOT=.. npm --prefix ui-workspace run lint:read-only",
    "ui:lint:packages": "UI_LINT_CANONICAL_ROOT=.. npm --prefix ui-workspace run lint:packages",
    "ui:lint:fixtures": "UI_LINT_CANONICAL_ROOT=.. npm --prefix ui-workspace run lint:fixtures",
    "ui:lint:theme": "UI_LINT_CANONICAL_ROOT=.. npm --prefix ui-workspace run lint:theme",
    "ui:lint:all": "UI_LINT_CANONICAL_ROOT=.. npm --prefix ui-workspace run lint:all",
    "renderer:web:dev": "npm run ui:dev",
    "renderer:web:build": "npm run ui:build",
    "renderer:web:preview": "npm run ui:preview"
  }
}
