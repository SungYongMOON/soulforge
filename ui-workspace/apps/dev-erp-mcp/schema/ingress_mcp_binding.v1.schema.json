{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://soulforge.local/schema/ingress_mcp_binding.v1.schema.json",
  "title": "Soulforge feature-gated ingress MCP binding",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "enabled", "node_id", "listen_host", "listen_port", "public_url",
    "local_outbox_binding_path", "auth_registry_path", "state_root", "submission_root",
    "max_file_bytes", "chunk_bytes", "ticket_ttl_seconds"
  ],
  "properties": {
    "schema_version": { "const": "soulforge.ingress.mcp_binding.v1" },
    "enabled": { "type": "boolean" },
    "node_id": { "$ref": "#/$defs/id" },
    "listen_host": { "const": "127.0.0.1" },
    "listen_port": { "type": "integer", "minimum": 1024, "maximum": 65535 },
    "public_url": { "type": "string", "format": "uri", "maxLength": 2048 },
    "local_outbox_binding_path": { "type": "string", "minLength": 1, "maxLength": 32767 },
    "auth_registry_path": { "type": "string", "minLength": 1, "maxLength": 32767 },
    "state_root": { "type": "string", "minLength": 1, "maxLength": 32767 },
    "submission_root": { "type": "string", "minLength": 1, "maxLength": 32767 },
    "max_file_bytes": { "type": "integer", "minimum": 1, "maximum": 2147483648 },
    "chunk_bytes": { "type": "integer", "minimum": 65536, "maximum": 16777216 },
    "ticket_ttl_seconds": { "type": "integer", "minimum": 60, "maximum": 86400 }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,127}$" }
  }
}
