{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://soulforge.local/schemas/ui-state.schema.json",
  "title": "Soulforge UI State vNext",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "source",
    "species",
    "units",
    "classes",
    "workflows",
    "parties",
    "workspaces",
    "diagnostics",
    "ui_hints"
  ],
  "additionalProperties": true,
  "properties": {
    "schema_version": {
      "const": "ui-state.v1"
    },
    "generated_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "source": {
      "$ref": "#/$defs/source"
    },
    "species": {
      "$ref": "#/$defs/axisCollection"
    },
    "units": {
      "$ref": "#/$defs/axisCollection"
    },
    "classes": {
      "$ref": "#/$defs/axisCollection"
    },
    "workflows": {
      "$ref": "#/$defs/axisCollection"
    },
    "parties": {
      "$ref": "#/$defs/axisCollection"
    },
    "workspaces": {
      "$ref": "#/$defs/workspaces"
    },
    "diagnostics": {
      "$ref": "#/$defs/diagnostics"
    },
    "ui_hints": {
      "$ref": "#/$defs/uiHints"
    },
    "overview": {
      "type": "object"
    },
    "body": {
      "type": "object"
    },
    "class_view": {
      "type": "object"
    },
    "catalogs": {
      "type": "object"
    }
  },
  "$defs": {
    "nullableString": {
      "type": [
        "string",
        "null"
      ]
    },
    "source": {
      "type": "object",
      "required": [
        "producer",
        "mode",
        "adapter",
        "fixture_name",
        "notes"
      ],
      "additionalProperties": true,
      "properties": {
        "producer": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "enum": [
            "fixture",
            "integration",
            "url"
          ]
        },
        "adapter": {
          "type": "string",
          "minLength": 1
        },
        "fixture_name": {
          "$ref": "#/$defs/nullableString"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "catalogItem": {
      "type": "object",
      "required": [
        "id",
        "display_name",
        "summary",
        "source_ref",
        "status"
      ],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "display_name": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string"
        },
        "source_ref": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "axisCollection": {
      "type": "object",
      "required": [
        "root",
        "owner",
        "items"
      ],
      "additionalProperties": true,
      "properties": {
        "root": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "catalog_ref": {
          "$ref": "#/$defs/nullableString"
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/catalogItem"
          }
        },
        "heroes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/catalogItem"
          }
        }
      }
    },
    "workspaces": {
      "type": "object",
      "required": [
        "root",
        "owner",
        "mode",
        "mount_status",
        "local_scan_enabled",
        "projects",
        "notes"
      ],
      "additionalProperties": true,
      "properties": {
        "root": {
          "type": "string",
          "const": "_workspaces"
        },
        "owner": {
          "type": "string",
          "const": "_workspaces"
        },
        "mode": {
          "type": "string",
          "const": "local_only_mount"
        },
        "mount_status": {
          "type": "string",
          "minLength": 1
        },
        "local_scan_enabled": {
          "type": "boolean"
        },
        "projects": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "diagnosticItem": {
      "type": "object",
      "required": [
        "code",
        "message",
        "severity",
        "location_hint"
      ],
      "additionalProperties": true,
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string"
        },
        "severity": {
          "type": "string",
          "enum": [
            "warning",
            "error"
          ]
        },
        "location_hint": {
          "$ref": "#/$defs/nullableString"
        }
      }
    },
    "diagnostics": {
      "type": "object",
      "required": [
        "summary",
        "warnings",
        "errors"
      ],
      "additionalProperties": true,
      "properties": {
        "summary": {
          "type": "object",
          "required": [
            "warnings",
            "errors",
            "highest_severity"
          ],
          "additionalProperties": true,
          "properties": {
            "warnings": {
              "type": "integer",
              "minimum": 0
            },
            "errors": {
              "type": "integer",
              "minimum": 0
            },
            "highest_severity": {
              "type": "string",
              "enum": [
                "ok",
                "warning",
                "error"
              ]
            }
          }
        },
        "warnings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/diagnosticItem"
          }
        },
        "errors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/diagnosticItem"
          }
        }
      }
    },
    "uiHints": {
      "type": "object",
      "required": [
        "theme",
        "phase",
        "default_tab",
        "layout",
        "material_hints",
        "icon_hints"
      ],
      "additionalProperties": true,
      "properties": {
        "theme": {
          "type": "string",
          "minLength": 1
        },
        "phase": {
          "type": "string",
          "minLength": 1
        },
        "default_tab": {
          "$ref": "#/$defs/nullableString"
        },
        "layout": {
          "type": "object",
          "required": [
            "left_ratio",
            "right_ratio",
            "gutter_ratio"
          ],
          "additionalProperties": true,
          "properties": {
            "left_ratio": {
              "type": "number"
            },
            "right_ratio": {
              "type": "number"
            },
            "gutter_ratio": {
              "type": "number"
            }
          }
        },
        "material_hints": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "icon_hints": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    }
  }
}
