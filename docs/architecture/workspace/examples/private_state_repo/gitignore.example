# private state repo allowlist template

# ignore by default
*

# keep git metadata helpers
!/.gitignore
!/README.md

# allow selected guild_hall state
!/guild_hall/
!/guild_hall/state/
!/guild_hall/state/gateway/
!/guild_hall/state/gateway/intake_inbox/
!/guild_hall/state/gateway/intake_inbox/**
!/guild_hall/state/gateway/mailbox/
!/guild_hall/state/gateway/mailbox/outbound/
!/guild_hall/state/gateway/mailbox/outbound/**
!/guild_hall/state/gateway/log/
!/guild_hall/state/gateway/log/monster_events/
!/guild_hall/state/gateway/log/monster_events/**
!/guild_hall/state/gateway/log/mail_send/
!/guild_hall/state/gateway/log/mail_send/**

# allow selected project worksite records
!/_workmeta/
!/_workmeta/*/
!/_workmeta/*/monsters/
!/_workmeta/*/monsters/**
!/_workmeta/*/log/
!/_workmeta/*/log/battle_log/
!/_workmeta/*/log/battle_log/**
!/_workmeta/*/reports/
!/_workmeta/*/reports/morning_report/
!/_workmeta/*/reports/morning_report/**

# explicit secret / volatile deny
guild_hall/state/gateway/mailbox/state/**
guild_hall/state/gateway/mailbox/**/raw/**
guild_hall/state/gateway/mailbox/**/events/**
guild_hall/state/gateway/mailbox/**/attachments/**
guild_hall/state/town_crier/**
_workmeta/*/runs/**
**/*.env
**/*token*
**/*cookie*
**/*.session
**/*.key

