{
  "version": "v0",
  "required_tools": [
    { "id": "git", "label": "Git", "command": ["git", "--version"] },
    { "id": "node", "label": "Node.js", "command": ["node", "--version"] },
    { "id": "npm", "label": "npm", "command": ["npm", "--version"] },
    { "id": "python3", "label": "Python 3", "command": ["python3", "--version"] },
    { "id": "uv", "label": "uv", "command": ["uv", "--version"] }
  ],
  "optional_tools": [
    { "id": "nlm", "label": "NotebookLM CLI", "command": ["nlm", "--version"] }
  ],
  "optional_skills": [
    "soulforge-shield-wall",
    "soulforge-record-stitch",
    "soulforge-skill-check"
  ],
  "required_local_files": [
    {
      "id": "email_fetch_env",
      "label": "gateway mail fetch env",
      "path": "guild_hall/state/gateway/mailbox/state/email_fetch.env",
      "template": "guild_hall/gateway/mail_fetch/email_fetch.env.example"
    },
    {
      "id": "mail_send_env",
      "label": "gateway outbound mail env",
      "path": "guild_hall/state/gateway/mailbox/state/mail_send.env",
      "template": "guild_hall/gateway/mail_send/mail_send.env.example"
    },
    {
      "id": "telegram_notify_env",
      "label": "town_crier telegram env",
      "path": "guild_hall/state/town_crier/telegram_notify.env",
      "template": "guild_hall/town_crier/telegram_notify.env.example"
    },
    {
      "id": "gateway_notify_policy",
      "label": "gateway notify policy",
      "path": "guild_hall/state/gateway/bindings/notify_policy.yaml",
      "template": "docs/architecture/workspace/examples/guild_hall/state/gateway/bindings/notify_policy.yaml"
    }
  ],
  "optional_local_paths": [
    {
      "id": "private_state_repo",
      "label": "private state repo",
      "path": "../Soulforge-private-state/.git",
      "note": "optional sibling private repo"
    }
  ],
  "safe_smokes": [
    {
      "id": "gateway_cli_syntax",
      "label": "gateway CLI syntax check",
      "command": ["node", "--check", "guild_hall/gateway/cli.mjs"]
    },
    {
      "id": "town_crier_status",
      "label": "town_crier status check",
      "command": ["node", "guild_hall/town_crier/cli.mjs", "status"]
    },
    {
      "id": "mail_fetch_py_compile",
      "label": "mail fetch Python compile check",
      "command": [
        "python3",
        "-m",
        "py_compile",
        "guild_hall/gateway/mail_fetch/cli.py",
        "guild_hall/gateway/mail_fetch/healthcheck.py",
        "guild_hall/town_crier/telegram_send.py"
      ]
    }
  ],
  "live_smokes": [
    {
      "id": "hiworks_pop3_live",
      "label": "Hiworks POP3 live auth",
      "command": "python3 guild_hall/doctor/live_checks.py"
    },
    {
      "id": "hiworks_smtp_live",
      "label": "Hiworks SMTP live auth",
      "command": "python3 guild_hall/doctor/live_checks.py"
    },
    {
      "id": "telegram_live",
      "label": "Telegram live auth",
      "command": "python3 guild_hall/doctor/live_checks.py"
    }
  ],
  "live_followups": [
    {
      "id": "gateway_fetch_once",
      "command": "npm run guild-hall:gateway:fetch -- --once --json"
    },
    {
      "id": "town_crier_status",
      "command": "npm run guild-hall:town-crier:status"
    },
    {
      "id": "town_crier_send",
      "command": "npm run guild-hall:town-crier:send -- --text \"doctor ready\""
    }
  ]
}
