{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "soulforge.slack_source_inventory.query_only.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "observed_at",
    "pagination_complete",
    "workspace_id",
    "channels",
    "history_probe"
  ],
  "properties": {
    "schema_version": {
      "const": "soulforge.slack_source_inventory.query_only.v1"
    },
    "observed_at": {
      "type": "string",
      "format": "date-time"
    },
    "pagination_complete": {
      "type": "boolean"
    },
    "workspace_id": {
      "type": "string",
      "pattern": "^T[A-Z0-9]{2,31}$"
    },
    "channels": {
      "type": "array",
      "maxItems": 500,
      "items": {
        "$ref": "#/$defs/channel"
      }
    },
    "history_probe": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/historyProbe"
        }
      ]
    }
  },
  "$defs": {
    "channel": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "channel_id",
        "classification_candidate",
        "project_code_candidate",
        "is_private",
        "is_archived",
        "is_shared",
        "is_ext_shared"
      ],
      "properties": {
        "channel_id": {
          "type": "string",
          "pattern": "^[CGD][A-Z0-9]{2,31}$"
        },
        "classification_candidate": {
          "enum": [
            "project_name_candidate",
            "other"
          ]
        },
        "project_code_candidate": {
          "anyOf": [
            {
              "type": "null"
            },
            {
              "type": "string",
              "pattern": "^P[0-9]{2}-[0-9]{3}$"
            }
          ]
        },
        "is_private": {
          "type": "boolean"
        },
        "is_archived": {
          "type": "boolean"
        },
        "is_shared": {
          "type": "boolean"
        },
        "is_ext_shared": {
          "type": "boolean"
        }
      }
    },
    "historyProbe": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "channel_id",
        "items_observed",
        "more_available",
        "latest_observed_at"
      ],
      "properties": {
        "channel_id": {
          "type": "string",
          "pattern": "^[CGD][A-Z0-9]{2,31}$"
        },
        "items_observed": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "more_available": {
          "type": "boolean"
        },
        "latest_observed_at": {
          "anyOf": [
            {
              "type": "null"
            },
            {
              "type": "string",
              "format": "date-time"
            }
          ]
        }
      }
    }
  }
}
