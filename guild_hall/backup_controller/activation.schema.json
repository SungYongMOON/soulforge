{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "soulforge.backup_controller.activation.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "binding_ref", "expected_binding_sha256", "runtime_commit_sha", "approval_ref", "writer", "feature_state", "not_before", "expires_at"],
  "properties": {
    "schema_version": { "const": "soulforge.backup_controller.activation.v1" },
    "binding_ref": { "type": "string", "minLength": 3 },
    "expected_binding_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "runtime_commit_sha": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
    "approval_ref": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{7,127}$" },
    "writer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["node_id", "hostname", "platform"],
      "properties": {
        "node_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{2,63}$" },
        "hostname": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{2,63}$" },
        "platform": { "const": "win32" }
      }
    },
    "feature_state": { "enum": ["off", "on"] },
    "not_before": { "type": "string", "format": "date-time" },
    "expires_at": { "type": "string", "format": "date-time" }
  }
}
