{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://soulforge.local/schemas/legacy-mail-custody-binding-v1.json",
  "title": "Soulforge legacy mail custody binding v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "snapshot_id",
    "source_root",
    "destination_root",
    "approval_ref",
    "expected_manifest_sha256",
    "files"
  ],
  "properties": {
    "schema_version": { "const": "soulforge.legacy_mail_custody_binding.v1" },
    "snapshot_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{2,127}$" },
    "source_root": { "type": "string", "minLength": 3 },
    "destination_root": { "type": "string", "minLength": 3 },
    "approval_ref": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{2,127}$" },
    "expected_manifest_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["relative_ref", "sha256", "size"],
        "properties": {
          "relative_ref": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "size": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
