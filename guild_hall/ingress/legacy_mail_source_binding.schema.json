{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://soulforge.local/schemas/legacy_mail_source_binding.v1.json",
  "title": "Soulforge explicit legacy mail source binding",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "hpp", "gateway", "erp"],
  "properties": {
    "schema_version": { "const": "soulforge.ingress.legacy_mail_source_binding.v1" },
    "hpp": {
      "type": "object",
      "additionalProperties": false,
      "required": ["event_files", "custody_index_file"],
      "properties": {
        "event_files": { "$ref": "#/$defs/file_array" },
        "custody_index_file": { "$ref": "#/$defs/jsonl_file" }
      }
    },
    "gateway": {
      "type": "object",
      "additionalProperties": false,
      "required": ["event_files"],
      "properties": { "event_files": { "$ref": "#/$defs/file_array" } }
    },
    "erp": {
      "type": "object",
      "additionalProperties": false,
      "required": ["normalized_files"],
      "properties": { "normalized_files": { "$ref": "#/$defs/file_array" } }
    }
  },
  "$defs": {
    "jsonl_file": { "type": "string", "minLength": 1, "pattern": "\\.[jJ][sS][oO][nN][lL]$" },
    "file_array": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/jsonl_file" }
    }
  }
}
