{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "soulforge.ingress.continuous_binding.v1",
  "oneOf": [
    { "$ref": "#/$defs/bindingV1" },
    { "$ref": "#/$defs/bindingV2" }
  ],
  "$defs": {
    "bindingV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "enabled",
        "scheduler_enabled",
        "node_id",
        "data_root",
        "poll_interval_seconds",
        "lease_ttl_seconds",
        "voice",
        "queues"
      ],
      "properties": {
        "schema_version": { "const": "soulforge.ingress.continuous_binding.v1" },
        "enabled": { "type": "boolean" },
        "scheduler_enabled": { "type": "boolean" },
        "node_id": { "$ref": "#/$defs/safeId" },
        "data_root": { "type": "string", "minLength": 3 },
        "poll_interval_seconds": { "type": "integer", "minimum": 30, "maximum": 86400 },
        "lease_ttl_seconds": { "type": "integer", "minimum": 60, "maximum": 172800 },
        "voice": { "$ref": "#/$defs/voice" },
        "queues": { "type": "array", "items": { "$ref": "#/$defs/queue" } }
      }
    },
    "bindingV2": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "enabled",
        "scheduler_enabled",
        "node_id",
        "data_root",
        "poll_interval_seconds",
        "lease_ttl_seconds",
        "writer_authority_record_path",
        "writer_mode",
        "mail",
        "voice",
        "queues"
      ],
      "properties": {
        "schema_version": { "const": "soulforge.ingress.continuous_binding.v2" },
        "enabled": { "type": "boolean" },
        "scheduler_enabled": { "type": "boolean" },
        "node_id": { "$ref": "#/$defs/safeId" },
        "data_root": { "type": "string", "minLength": 3 },
        "poll_interval_seconds": { "type": "integer", "minimum": 30, "maximum": 86400 },
        "lease_ttl_seconds": { "type": "integer", "minimum": 60, "maximum": 172800 },
        "writer_authority_record_path": { "type": "string", "minLength": 3 },
        "writer_mode": { "enum": ["primary", "fallback"] },
        "mail": { "$ref": "#/$defs/mail" },
        "voice": { "$ref": "#/$defs/voice" },
        "queues": { "type": "array", "items": { "$ref": "#/$defs/queue" } }
      }
    },
    "safeId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,127}$"
    },
    "digest": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "mail": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "python_executable",
        "team_cli_path",
        "team_cli_sha256",
        "collector_tree_sha256",
        "register_path",
        "register_sha256",
        "private_config_root",
        "limit"
      ],
      "properties": {
        "enabled": { "type": "boolean" },
        "python_executable": { "type": ["string", "null"], "minLength": 3 },
        "team_cli_path": { "type": ["string", "null"], "minLength": 3 },
        "team_cli_sha256": {
          "anyOf": [
            { "$ref": "#/$defs/digest" },
            { "type": "null" }
          ]
        },
        "collector_tree_sha256": {
          "anyOf": [
            { "$ref": "#/$defs/digest" },
            { "type": "null" }
          ]
        },
        "register_path": { "type": ["string", "null"], "minLength": 3 },
        "register_sha256": {
          "anyOf": [
            { "$ref": "#/$defs/digest" },
            { "type": "null" }
          ]
        },
        "private_config_root": { "type": ["string", "null"], "minLength": 3 },
        "limit": { "type": "integer", "minimum": 1, "maximum": 1000 }
      },
      "allOf": [
        {
          "if": { "properties": { "enabled": { "const": true } }, "required": ["enabled"] },
          "then": {
            "properties": {
              "python_executable": { "type": "string", "minLength": 3 },
              "team_cli_path": { "type": "string", "minLength": 3 },
              "team_cli_sha256": { "$ref": "#/$defs/digest" },
              "collector_tree_sha256": { "$ref": "#/$defs/digest" },
              "register_path": { "type": "string", "minLength": 3 },
              "register_sha256": { "$ref": "#/$defs/digest" },
              "private_config_root": { "type": "string", "minLength": 3 }
            }
          }
        }
      ]
    },
    "voice": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "source_root",
        "destination_root",
        "legacy_root",
        "state_root",
        "checkpoint_path",
        "receipt_root",
        "source_owner_ref",
        "lanes",
        "max_new_files",
        "max_new_bytes"
      ],
      "properties": {
        "enabled": { "type": "boolean" },
        "source_root": { "type": "string", "minLength": 3 },
        "destination_root": { "type": "string", "minLength": 3 },
        "legacy_root": { "type": ["string", "null"] },
        "state_root": { "type": "string", "minLength": 3 },
        "checkpoint_path": { "type": "string", "minLength": 3 },
        "receipt_root": { "type": "string", "minLength": 3 },
        "source_owner_ref": { "$ref": "#/$defs/safeId" },
        "lanes": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/safeId" } },
        "max_new_files": { "type": "integer", "minimum": 1, "maximum": 10000 },
        "max_new_bytes": { "type": "integer", "minimum": 1 }
      }
    },
    "queue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "binding_id",
        "enabled",
        "lane",
        "source_root",
        "ack_root",
        "source_owner_ref",
        "max_files_per_run",
        "max_bytes_per_run"
      ],
      "properties": {
        "binding_id": { "$ref": "#/$defs/safeId" },
        "enabled": { "type": "boolean" },
        "lane": { "enum": ["team_files", "structured_pc_work", "run_logs"] },
        "source_root": { "type": "string", "minLength": 3 },
        "ack_root": { "type": "string", "minLength": 3 },
        "source_owner_ref": { "$ref": "#/$defs/safeId" },
        "max_files_per_run": { "type": "integer", "minimum": 1, "maximum": 10000 },
        "max_bytes_per_run": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
