# Outbound mail placeholder
# 실제 값은 guild_hall/state/gateway/mailbox/state/mail_send.env 에서만 관리한다.

EMAIL_SEND_ENABLED=false
EMAIL_SEND_PROVIDER=hiworks

HIWORKS_SMTP_HOST=
HIWORKS_SMTP_PORT=
HIWORKS_SMTP_USERNAME=
HIWORKS_SMTP_PASSWORD=
# 또는 HIWORKS_SMTP_PASSWORD_FILE=./hiworks_smtp_password.txt
HIWORKS_SMTP_USE_SSL=
HIWORKS_SMTP_USE_STARTTLS=
HIWORKS_SMTP_FROM=
