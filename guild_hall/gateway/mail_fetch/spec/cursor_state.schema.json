{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "email.fetch.cursor.v1",
  "title": "Email Fetch Cursor State",
  "type": "object",
  "required": ["schema_version", "sources", "updated_at"],
  "properties": {
    "schema_version": { "const": "email.fetch.cursor.v1" },
    "updated_at": { "type": "string", "format": "date-time" },
    "sources": {
      "type": "object",
      "required": ["gmail", "hiworks", "o365"],
      "properties": {
        "gmail": { "$ref": "#/$defs/sourceState" },
        "hiworks": { "$ref": "#/$defs/sourceState" },
        "o365": { "$ref": "#/$defs/sourceState" }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "sourceState": {
      "type": "object",
      "required": ["cursor", "updated_at"],
      "properties": {
        "cursor": {
          "type": ["object", "null"],
          "additionalProperties": true
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
