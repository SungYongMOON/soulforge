# Soulforge gateway mail fetch env
# 기본 위치: guild_hall/state/gateway/mailbox/state/email_fetch.env

# 실행/저장 경로
EMAIL_FETCH_RUNTIME_DIR=/path/to/Soulforge/guild_hall/state/gateway/log/mail_fetch
EMAIL_FETCH_INBOX_ROOT=/path/to/Soulforge/guild_hall/state/gateway/mailbox

# 수집 기본값
EMAIL_FETCH_LIMIT=50
EMAIL_FETCH_RETRY_MAX=3
EMAIL_FETCH_DRY_RUN=false
EMAIL_FETCH_STATE_BACKUP_KEEP=30

# 첨부 정책
EMAIL_FETCH_ATTACHMENT_MAX_BYTES=31457280
EMAIL_FETCH_ALLOWED_LINK_HOSTS=drive.google.com,docs.google.com,onedrive.live.com,*.sharepoint.com,dropbox.com
EMAIL_FETCH_DENIED_LINK_HOSTS=
EMAIL_FETCH_BLOCKED_ATTACHMENT_EXTS=.exe,.msi,.dmg,.pkg,.bat,.cmd,.ps1,.js,.vbs,.scr,.dll,.jar,.apk,.iso,.img,.com,.pif,.app
EMAIL_FETCH_LINK_DOWNLOAD_ENABLED=false
EMAIL_FETCH_LINK_DOWNLOAD_TIMEOUT_SEC=20
EMAIL_FETCH_LINK_DOWNLOAD_MAX_BYTES=31457280
EMAIL_FETCH_LINK_DOWNLOAD_RETRY_MAX=3
EMAIL_FETCH_AD_KEYWORDS=[광고],수신거부,unsubscribe,newsletter,프로모션,promotion,special offer
EMAIL_FETCH_AD_SENDER_DOMAINS=

# 운영 헬스체크/알림
EMAIL_FETCH_HEALTH_MAX_STALE_SEC=900
EMAIL_FETCH_HEALTH_FAIL_STREAK=2
EMAIL_FETCH_HEALTH_PARTIAL_STREAK=3
EMAIL_FETCH_HEALTH_ALERT_COOLDOWN_SEC=3600
EMAIL_FETCH_ALERT_TELEGRAM_ENABLED=false
# EMAIL_FETCH_ALERT_TELEGRAM_BOT_TOKEN=
EMAIL_FETCH_ALERT_TELEGRAM_CHAT_ID=

# 보존/정리
EMAIL_FETCH_RETENTION_REPORT_ONLY=true
EMAIL_FETCH_RETENTION_TRASH_GRACE_DAYS=14

# 소스 활성화
EMAIL_FETCH_SOURCE_GMAIL_ENABLED=true
EMAIL_FETCH_SOURCE_HIWORKS_ENABLED=true
EMAIL_FETCH_SOURCE_O365_ENABLED=false

# gateway mailbox bucket 매핑
EMAIL_FETCH_WORKSPACE_GMAIL=personal
EMAIL_FETCH_WORKSPACE_HIWORKS=company
EMAIL_FETCH_WORKSPACE_O365=company

# Gmail 인증
# GMAIL_ACCESS_TOKEN=
# GMAIL_REFRESH_TOKEN=
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# GMAIL_TOKEN_URI=https://oauth2.googleapis.com/token
# GMAIL_ACCESS_TOKEN_EXPIRES_AT=
# GMAIL_ACCESS_TOKEN_FILE=./gmail_access_token.json

# Gmail API 옵션
GMAIL_USER_ID=me
GMAIL_TIMEOUT_SEC=30
EMAIL_FETCH_GMAIL_INITIAL_DAYS=3
EMAIL_FETCH_GMAIL_LABEL_IDS=INBOX
EMAIL_FETCH_GMAIL_QUERY=
EMAIL_FETCH_GMAIL_INCLUDE_SPAM_TRASH=false

# Hiworks POP3 옵션
# HIWORKS_POP3_HOST=pop3.mail.example.com
HIWORKS_POP3_PORT=995
# HIWORKS_POP3_USERNAME=your-id@company.com
# HIWORKS_POP3_PASSWORD=
# HIWORKS_POP3_PASSWORD_FILE=./hiworks_pop3_password.txt
HIWORKS_POP3_USE_SSL=true
HIWORKS_POP3_TIMEOUT_SEC=30
HIWORKS_POP3_SEEN_WINDOW=5000
