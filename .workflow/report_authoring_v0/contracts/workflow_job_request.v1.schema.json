{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "soulforge.workflow_job_request.v1",
  "title": "Soulforge workflow job request v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "job_id",
    "idempotency_key",
    "workflow_id",
    "workflow_binding_revision",
    "mode",
    "project_code",
    "actor_ref",
    "input_refs",
    "report_type",
    "audience",
    "output_formats",
    "boundary_policy",
    "acceptance_profile"
  ],
  "properties": {
    "schema": { "const": "soulforge.workflow_job_request.v1" },
    "job_id": { "$ref": "#/$defs/safe_id" },
    "idempotency_key": { "$ref": "#/$defs/safe_id" },
    "workflow_id": { "const": "report_authoring_v0" },
    "workflow_binding_revision": { "const": "report_authoring_v0.binding.v1" },
    "mode": { "enum": ["full_authoring", "final_polish"] },
    "project_code": { "$ref": "#/$defs/safe_id" },
    "actor_ref": { "$ref": "#/$defs/opaque_ref" },
    "input_refs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": { "$ref": "#/$defs/input_ref" }
    },
    "report_type": { "enum": ["experiment", "analysis", "progress", "presentation", "other"] },
    "audience": { "enum": ["internal_review", "management", "customer", "regulator", "other"] },
    "output_formats": {
      "type": "array",
      "minItems": 1,
      "maxItems": 2,
      "uniqueItems": true,
      "contains": { "const": "md" },
      "items": { "enum": ["md", "html"] }
    },
    "boundary_policy": { "const": "soulforge.report.boundary.v1" },
    "acceptance_profile": { "const": "soulforge.report.semantic_preservation.v1" }
  },
  "allOf": [
    {
      "if": { "properties": { "mode": { "const": "full_authoring" } }, "required": ["mode"] },
      "then": { "properties": { "input_refs": { "type": "array", "contains": { "type": "object", "properties": { "role": { "const": "source_material" } }, "required": ["role"] } } } }
    },
    {
      "if": { "properties": { "mode": { "const": "final_polish" } }, "required": ["mode"] },
      "then": { "properties": { "input_refs": { "type": "array", "contains": { "type": "object", "properties": { "role": { "const": "draft_report" } }, "required": ["role"] } } } }
    }
  ],
  "$defs": {
    "safe_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 96,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "opaque_ref": {
      "type": "string",
      "minLength": 3,
      "maxLength": 224,
      "pattern": "^[a-z][a-z0-9_-]{1,31}:[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "input_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "payload_ref", "sha256", "size", "media_type"],
      "properties": {
        "role": { "enum": ["source_material", "draft_report", "owner_contract", "semantic_manifest"] },
        "payload_ref": { "$ref": "#/$defs/opaque_ref" },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "size": { "type": "integer", "minimum": 1, "maximum": 8388608 },
        "media_type": { "enum": ["application/json", "text/markdown", "text/plain"] }
      }
    }
  }
}
