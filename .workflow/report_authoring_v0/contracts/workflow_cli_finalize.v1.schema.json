{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "soulforge.workflow_cli_finalize.v1",
  "title": "Soulforge workflow CLI finalize config v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "request", "expected_workflow_bundle_sha256", "payload_bindings", "allowed_payload_roots", "artifact_root", "artifact_storage_class", "owner_approval_ref", "state_root", "identity_authority_record_sha256", "prepared"],
  "properties": {
    "schema": { "const": "soulforge.workflow_cli_finalize.v1" },
    "request": { "type": "object" },
    "expected_workflow_bundle_sha256": { "$ref": "#/$defs/sha256" },
    "payload_bindings": { "type": "object", "minProperties": 1, "additionalProperties": { "type": "string", "minLength": 1 } },
    "allowed_payload_roots": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "artifact_root": { "type": "string", "minLength": 1 },
    "artifact_storage_class": { "enum": ["workspace_system", "owner_approved_shared_worksite"] },
    "owner_approval_ref": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/opaque_ref" }] },
    "state_root": { "type": "string", "minLength": 1 },
    "identity_authority_record_sha256": { "$ref": "#/$defs/sha256" },
    "prepared": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protected_baseline", "draft", "technical_content", "evidence_logic", "derive_executive_summary", "final_polish", "semantic_verifier"],
      "properties": {
        "protected_baseline": { "type": ["object", "null"] },
        "draft": { "type": ["object", "null"] },
        "technical_content": { "type": ["object", "null"] },
        "evidence_logic": { "type": ["object", "null"] },
        "derive_executive_summary": { "type": ["object", "null"] },
        "final_polish": { "type": ["object", "null"] },
        "semantic_verifier": { "type": "object" }
      }
    }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "opaque_ref": { "type": "string", "pattern": "^[a-z][a-z0-9_-]{1,31}:[A-Za-z0-9][A-Za-z0-9._:-]*$" }
  }
}
