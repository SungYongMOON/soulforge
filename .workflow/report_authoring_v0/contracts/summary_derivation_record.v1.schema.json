{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "soulforge.summary_derivation_record.v1",
  "title": "Soulforge body-derived summary record v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "status", "verified_body_sha256", "derived_document_sha256", "body_claim_refs", "summary_assertions"],
  "properties": {
    "schema": { "const": "soulforge.summary_derivation_record.v1" },
    "status": { "const": "pass" },
    "verified_body_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "derived_document_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "body_claim_refs": { "type": "array", "maxItems": 4096, "uniqueItems": true, "items": { "$ref": "#/$defs/safe_id" } },
    "summary_assertions": { "type": "array", "maxItems": 256, "items": { "$ref": "#/$defs/summary_assertion" } }
  },
  "$defs": {
    "safe_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,95}$" },
    "opaque_ref": { "type": "string", "pattern": "^[a-z][a-z0-9_-]{1,31}:[A-Za-z0-9][A-Za-z0-9._:-]*$" },
    "summary_assertion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["section_id", "block_id", "sentence_id", "sentence_sha256", "claim_refs", "source_refs", "citation_refs"],
      "properties": {
        "section_id": { "$ref": "#/$defs/safe_id" },
        "block_id": { "$ref": "#/$defs/safe_id" },
        "sentence_id": { "$ref": "#/$defs/safe_id" },
        "sentence_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "claim_refs": { "type": "array", "minItems": 1, "maxItems": 4096, "uniqueItems": true, "items": { "$ref": "#/$defs/safe_id" } },
        "source_refs": { "type": "array", "maxItems": 64, "uniqueItems": true, "items": { "$ref": "#/$defs/opaque_ref" } },
        "citation_refs": { "type": "array", "maxItems": 64, "uniqueItems": true, "items": { "$ref": "#/$defs/safe_id" } }
      }
    }
  }
}
